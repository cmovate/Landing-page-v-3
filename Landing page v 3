    <style>h
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        
        :root {
            --green-dark: #1a3a2a;
            --green-mid: #2d6a4f;
            --accent: #52b788;
            --cream: #f8f5f0;
            --text: #1c1c1c;
            --muted: #4b5563;
            --white: #ffffff;
        }

        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--white);
            color: var(--text);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- HEADER --- */
        .site-header {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            padding: 0 7%;
            height: 90px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255,255,255,0.98);
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }
        .header-logo img { height: 50px; width: auto; display: block; }
        .header-nav { display: flex; gap: 40px; }
        .header-nav a { font-size: 0.9rem; font-weight: 600; text-transform: uppercase; color: var(--text); text-decoration: none; transition: color 0.3s; }
        .header-nav a:hover { color: var(--accent); }
        .header-cta { background: var(--accent); color: var(--white); padding: 12px 28px; border-radius: 50px; text-decoration: none; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; }

        /* --- HERO --- */
        .hero {
            padding: 160px 8% 100px;
            background: linear-gradient(135deg, #f0faf5 0%, #d8f3dc 100%);
            display: flex;
            align-items: center;
            position: relative;
            min-height: 80vh;
        }
        .hero-text { max-width: 600px; z-index: 2; }
        .hero-text h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 5vw, 4rem); line-height: 1.1; color: var(--green-dark); margin-bottom: 10px; }
        .hero-text .script { 
            font-family: 'Cormorant Upright', serif; 
            font-size: clamp(2.6rem, 4.5vw, 4.2rem); 
            font-weight: 600; 
            color: var(--accent); 
            display: block; 
            margin-bottom: 30px; 
        }
        .hero-text p { font-size: 1.1rem; color: var(--muted); margin-bottom: 40px; max-width: 480px; font-weight: 400; }
        .btn-primary { display: inline-block; background: var(--green-dark); color: var(--white); padding: 16px 36px; text-decoration: none; font-weight: 600; transition: background 0.3s; }
        .btn-primary:hover { background: var(--accent); }
        .hero-image { position: absolute; right: 0; top: 0; width: 45%; height: 100%; overflow: hidden; }
        .hero-image img { width: 100%; height: 100%; object-fit: cover; -webkit-mask-image: linear-gradient(to right, transparent 0%, black 25%); }

        /* --- TWO-ROW LOGO MARQUEE --- */
        .clients-marquee { padding: 60px 0; background: var(--white); overflow: hidden; border-bottom: 1px solid #eee; }
        .marquee-wrapper { display: flex; flex-direction: column; gap: 40px; }
        .marquee-row { display: flex; overflow: hidden; width: 100%; }
        .marquee-track { display: flex; gap: 80px; width: max-content; align-items: center; }
        .track-left { animation: scroll-left 50s linear infinite; }
        .track-right { animation: scroll-right 50s linear infinite; }
        @keyframes scroll-left { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        @keyframes scroll-right { 0% { transform: translateX(-50%); } 100% { transform: translateX(0); } }
        .logo-item img { height: 35px; width: auto; opacity: 1; filter: saturate(100%); display: block; }

        /* --- CARE --- */
        .care { background: var(--green-dark); color: var(--white); padding: 120px 8%; text-align: center; }
        .care blockquote { font-family: 'Playfair Display', serif; font-style: italic; font-size: clamp(2.2rem, 5vw, 3.8rem); margin-bottom: 30px; }
        .care .care-word { color: var(--accent); }
        .care p { color: #e0e0e0; max-width: 700px; margin: 0 auto; font-size: 1.2rem; font-weight: 400; }

        /* --- EXECUTION FRAMEWORK --- */
        .execution { padding: 100px 8%; background: var(--white); border-bottom: 1px solid #eee; }
        .execution-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
        .execution-left h2 { font-family: 'Playfair Display', serif; font-size: 3.5rem; color: var(--green-dark); font-style: italic; line-height: 1.1; }
        .execution-left h2 strong { display: block; font-style: normal; color: var(--text); margin-top: 10px; }
        .execution-right { display: grid; gap: 40px; }
        .exec-step h3 { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--green-dark); margin-bottom: 10px; }
        .exec-step p { color: var(--muted); font-size: 1rem; font-weight: 400; }

        /* --- WHAT WE DO BEST --- */
        .services { padding: 100px 8%; background: var(--cream); text-align: center; }
        .services h2 { font-family: 'Playfair Display', serif; font-size: 3rem; margin-bottom: 60px; font-style: italic; }
        .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
        .service-card { padding: 50px; background: var(--white); border-radius: 12px; transition: 0.3s; text-align: left; box-shadow: 0 4px 15px rgba(0,0,0,0.02); }
        .service-card:hover { transform: translateY(-10px); border-color: var(--accent); }
        .service-card .num { font-family: 'Playfair Display', serif; font-style: italic; font-size: 2.8rem; color: var(--accent); display: block; margin-bottom: 20px; opacity: 1 !important; }
        .service-card h3 { font-size: 1.4rem; color: var(--green-dark); margin-bottom: 15px; }
        .service-card p { font-weight: 400; color: var(--muted); }

        /* --- TESTIMONIALS (THE WORD) --- */
        .testimonials { padding: 100px 0; background: var(--white); overflow: hidden; }
        .testimonials h2 { text-align: center; font-family: 'Playfair Display', serif; font-style: italic; font-size: 3rem; margin-bottom: 50px; }
        .testimonials-track { display: flex; gap: 25px; padding: 20px 0; width: max-content; animation: scroll-testimonials 110s linear infinite; }
        .testimonials-track:hover { animation-play-state: paused; }
        @keyframes scroll-testimonials { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        .testimonial-card { 
            background: var(--white); 
            width: 500px; 
            padding: 45px; 
            border-radius: 16px; 
            border: 1px solid #f0f0f0; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.04); 
            display: flex; 
            flex-direction: column; 
            justify-content: space-between; 
        }
        .quote-text { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.05rem; line-height: 1.7; color: var(--green-dark); margin-bottom: 25px; font-weight: 400; }
        .author-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 20px; border-top: 1px solid #f5f5f5; }
        .author-name { font-weight: 700; font-size: 0.95rem; color: var(--text); }
        .author-title { font-size: 0.75rem; color: var(--accent); text-transform: uppercase; font-weight: 600; letter-spacing: 0.05em; }
        .company-logo-img { height: 28px; max-width: 120px; object-fit: contain; filter: grayscale(0%); opacity: 1; }
        

        /* --- CONTACT --- */
        .contact { padding: 100px 8%; background: var(--cream); }
        .contact-inner { max-width: 700px; margin: 0 auto; padding: 60px; background: var(--white); border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.03); text-align: center; }
        .contact h2 { font-family: 'Playfair Display', serif; font-size: 3rem; font-style: italic; margin-bottom: 40px; }
        .form-field { margin-bottom: 25px; }
        .form-field input { width: 100%; padding: 15px; border: none; border-bottom: 1px solid #ddd; outline: none; font-size: 1rem; font-family: 'Inter', sans-serif; }
        .form-field input:focus { border-bottom-color: var(--accent); }
        .btn-send { background: var(--green-dark); color: white; border: none; padding: 18px; width: 100%; cursor: pointer; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; transition: 0.3s; }
        .btn-send:hover { background: var(--accent); }

        @media (max-width: 900px) {
            .hero { flex-direction: column; padding-top: 120px; text-align: center; }
            .hero-image { display: none; }
            .execution-inner { grid-template-columns: 1fr; gap: 40px; }
